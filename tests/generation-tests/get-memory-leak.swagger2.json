{
  "swagger": "2.0",
  "info": {
    "title": "Neutral API",
    "version": "0.1"
  },
  "basePath": "/_neutral/",
  "schemes": ["https", "http"],
  "produces": ["application/json"],
  "paths": {
    "/api/v1/memory/leak": {
      "get": {
        "operationId": "getMemoryLeak",
        "summary": "Нейтральный бинарный отчёт",
        "tags": ["neutral"],
        "produces": [
          "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "cursor",
            "required": true,
            "type": "string"
          },
          {
            "collectionFormat": "multi",
            "in": "query",
            "items": { "type": "string" },
            "name": "filters",
            "type": "array"
          }
        ],
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": { "$ref": "#/definitions/NeutralBinaryPayload" }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": { "$ref": "#/definitions/NeutralStatus" }
          }
        }
      }
    }
  },
  "definitions": {
    "NeutralBinaryPayload": {
      "type": "object",
      "properties": {
        "data": { "format": "byte", "type": "string" }
      }
    },
    "NeutralStatus": {
      "type": "object",
      "properties": {
        "code": { "format": "int32", "type": "integer" },
        "message": { "type": "string" }
      }
    }
  }
}

