  {
    params: ({ requestParams }) => ({
      baseUrl: "https://{env}.api.example.com:{port}/{basePath}",
      path: \`/status\`,
      method: "GET",
      format: "json",
      ...requestParams,
    }),
    requiredParams: [],
    operationId: "getServerVariables",
    path: ["status"],
