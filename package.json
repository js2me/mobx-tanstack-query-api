{
  "version": "0.43.0",
  "name": "mobx-tanstack-query-api",
  "description": "OpenAPI/Swagger client codegen + endpoints integration with mobx-tanstack-query",
  "scripts": {
    "prepare": "pnpm dev:install-hooks",
    "clean": "rimraf dist",
    "lint:check": "pnpm exec biome check --write --no-errors-on-unmatched --files-ignore-unknown=true",
    "ts:check": "tsc --noEmit",
    "check": "npm run lint:check && npm run ts:check",
    "prebuild": "npm run clean && npm run check",
    "build:watch": "pnpm build && nodemon --delay 0.5 --watch src --ext ts,tsx --exec \"pnpm build\"",
    "build": "vite build",
    "pub": "pnpm build && sborshik publish --useDistDir",
    "pub:patch": "PUBLISH_VERSION=patch pnpm run build",
    "pub:minor": "PUBLISH_VERSION=minor pnpm run build",
    "pub:major": "PUBLISH_VERSION=major pnpm run build",
    "test": "vitest run --config vitest.config.ts",
    "test:update": "vitest run --config vitest.config.ts --update",
    "test:watch": "vitest watch --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "docs": "pnpm build && cd docs && pnpm dev",
    "docs:install": "cd docs && pnpm i",
    "docs:build": "cd docs && pnpm build",
    "docs:serve": "cd docs && pnpm preview",
    "dev": "pnpm build && nodemon --delay 0.5 --watch src --ext ts,tsx --exec \"pnpm build && pnpm playground\"",
    "playground": "node ./playground/index.mjs",
    "dev:install-hooks": "if [ -z \"$CI\" ]; then lefthook install; fi"
  },
  "keywords": [
    "mobx",
    "react-query",
    "tanstack-query",
    "openapi",
    "swagger",
    "codegen"
  ],
  "author": "js2me",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/js2me/mobx-tanstack-query-api/issues"
  },
  "homepage": "https://github.com/js2me/mobx-tanstack-query-api",
  "repository": {
    "type": "git",
    "url": "git://github.com/js2me/mobx-tanstack-query-api"
  },
  "peerDependencies": {
    "mobx": "^6.13.6",
    "zod": ">=4"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "@tanstack/query-core": "^5.96.1",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/qs": "^6.15.0",
    "cac": "^7.0.0",
    "http-status-code-types": "^1.0.1",
    "jiti": "^2.6.1",
    "lodash-es": "^4.18.1",
    "mobx-tanstack-query": "^6.14.0",
    "qs": "^6.15.0",
    "swagger-typescript-api": "^13.6.6",
    "ts-morph": "^27.0.2",
    "undici-types": "^7.24.7",
    "yummies": "^7.12.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-istanbul": "^4.1.2",
    "commitfmt": "^1.0.4",
    "js2me-biome-config": "^1.1.0",
    "jsdom": "^29.0.1",
    "lefthook": "^1.13.6",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "sborshik": "^3.0.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@9.5.0+sha512.140036830124618d624a2187b50d04289d5a087f326c9edfc0ccd733d76c4f52c3a313d4fc148794a2a9d81553016004e6742e8cf850670268a7387fc220c903"
}